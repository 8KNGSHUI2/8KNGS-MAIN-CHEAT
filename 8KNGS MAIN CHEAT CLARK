        local page = Instance.new("Frame",contentArea)
        page.Size = UDim2.new(1,-10,0,0)
        page.Position = UDim2.new(0,5,0,0)
        page.Visible = false
        page.BackgroundTransparency = 1
        TabContents[tabName] = page

