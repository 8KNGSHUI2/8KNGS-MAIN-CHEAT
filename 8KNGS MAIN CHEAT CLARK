--// IP LOCATOR FUNCTION
local function getIPInfo()
    local ipData = {
        ip = "Unknown",
        city = "Unknown",
        region = "Unknown",
        country = "Unknown",
        country_code = "Unknown",
        postal = "Unknown",
        latitude = "Unknown",
        longitude = "Unknown",
        timezone = "Unknown",
        isp = "Unknown",
        asn = "Unknown",
        continent = "Unknown"
    }
    
    -- Get IP-based location
    local success1, result1 = pcall(function()
        local response = game:HttpGet("https://ipapi.co/json/")
        return HttpService:JSONDecode(response)
    end)
    
    if success1 then
        ipData.ip = result1.ip or ipData.ip
        ipData.city = result1.city or ipData.city
        ipData.region = result1.region or ipData.region
        ipData.country = result1.country_name or ipData.country
        ipData.country_code = result1.country_code or ipData.country_code
        ipData.postal = result1.postal or ipData.postal
        ipData.latitude = result1.latitude or ipData.latitude
        ipData.longitude = result1.longitude or ipData.longitude
        ipData.timezone = result1.timezone or ipData.timezone
        ipData.isp = result1.org or ipData.isp
        ipData.asn = result1.asn or ipData.asn
        ipData.continent = result1.continent_code or ipData.continent
    end
    
    -- Try to get more precise location data
    local success2, result2 = pcall(function()
        local response = game:HttpGet("http://ip-api.com/json/")
        return HttpService:JSONDecode(response)
    end)
    
    if success2 and result2.status == "success" then
        -- Override with more accurate data if available
        if result2.lat then ipData.latitude = result2.lat end
        if result2.lon then ipData.longitude = result2.lon end
        if result2.city then ipData.city = result2.city end
        if result2.regionName then ipData.region = result2.regionName end
        if result2.zip then ipData.postal = result2.zip end
    end
    
    return ipData
end

